# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=geoyield

# Host port for the db container. 5433 by default to avoid clashing with a
# local Postgres install on 5432.
POSTGRES_HOST_PORT=5433

# Used by the api service (db = compose service name, internal port 5432)
DATABASE_URL=postgresql://postgres:postgres@db:5432/geoyield
